# =========================
# Project folders to ignore
# =========================

# Do not commit docs
docs/

# Do not commit raw dataset files
data/raw/*
!data/raw/.gitkeep

# Do not commit generated processed CSV files
data/processed/*.csv
data/processed/*.json

# Keep small cleaning summary file
!data/processed/data_cleaning_summary.csv

# Do not commit EDA generated summary tables
data/processed/eda_summary_tables/

# Keep processed folder structure if needed
!data/processed/.gitkeep

# =========================
# MLflow / model artifacts
# =========================

mlruns/
models/mlruns/
models/*.pkl
models/*.joblib
models/*.pickle

# =========================
# Jupyter / Python
# =========================

.ipynb_checkpoints/
**/.ipynb_checkpoints/
__pycache__/
*.pyc

# =========================
# Environment / secrets
# =========================

.env
.env.*
.venv/
venv/

# =========================
# System files
# =========================

.DS_Store
Thumbs.db
